{
  "name": "@liogi/wtree",
  "version": "0.1.0",
  "description": "Git worktree manager with .env syncing and IDE integration",
  "type": "module",
  "bin": {
    "wtree": "./dist/index.js",
    "wt": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "postbuild": "chmod +x dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "commander": "^12.0.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "git",
    "worktree",
    "cli",
    "ide",
    "dev-tools"
  ],
  "author": "Lionel Giberné",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/liogi/wtree.git"
  }
